# Airport capacity (required)
# Comma-separated runway lengths in meters; runway count = number of values
ATC_RUNWAY_LENGTHS=2500,3000,3500
# Optional cross-check: must equal the number of runway lengths above
ATC_RUNWAY_COUNT=3
ATC_GATE_COUNT=4
ATC_GROUND_CREW_COUNT=3

# Runway separation buffers (minutes, same runway)
ATC_SEPARATION_TAKEOFF_MINUTES=2
ATC_SEPARATION_LANDING_MINUTES=3
ATC_SEPARATION_MIXED_MINUTES=4

# Gate and dependency timing (minutes)
ATC_GATE_TURNAROUND_MINUTES=45
ATC_DEPENDENCY_BUFFER_MINUTES=30

# Scheduling limit (minutes from schedule start)
ATC_MAX_SCHEDULING_HORIZON_MINUTES=1440

# Default operation block times (optional; used by scheduler in later steps)
ATC_ARRIVAL_DURATION_MINUTES=30
ATC_DEPARTURE_DURATION_MINUTES=25
